# Copy to .env and fill in as needed. All values are optional for the MVP:
# tests and the CLI run against fixture data without any of this configured.

# Kaggle API credentials (https://www.kaggle.com/settings -> Create New Token)
# Required only for scripts/download_data.py when fetching piterfm/fifa-football-world-cup.
KAGGLE_USERNAME=
KAGGLE_KEY=

# Override any path from configs/data.yaml at runtime if needed.
WORLDCUP_DATA_DIR=data
WORLDCUP_OUTPUT_DIR=outputs

# Logging verbosity: DEBUG, INFO, WARNING, ERROR
WORLDCUP_LOG_LEVEL=INFO
