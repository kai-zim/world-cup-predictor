# Copy this file to .env and fill in real values.
# .env is git-ignored; never commit secrets.

# ── MLflow ────────────────────────────────────────────────────────────────────
# Local file-based tracking (default). Set to a remote URI for a shared server.
MLFLOW_TRACKING_URI=mlruns

# ── Optional data-source credentials ─────────────────────────────────────────
# Kaggle API key for automatic dataset download (martj42/international-football-results).
# Generate at https://www.kaggle.com/settings → API → Create New Token.
KAGGLE_USERNAME=
KAGGLE_KEY=

# ── Application settings ──────────────────────────────────────────────────────
# Override any AppConfig value via environment variables with WCP_ prefix
# (handled by pydantic-settings in src/wc2026/config/schema.py).
# Example:
# WCP_SIMULATION__N_SIMULATIONS=50000