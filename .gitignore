# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.egg-info/
dist/
build/
*.egg

# Virtual environments
.venv/
venv/
env/
.env

# Testing / coverage
.coverage
.coverage.*
htmlcov/
.pytest_cache/

# Type checkers / linters
.mypy_cache/
.ruff_cache/

# MLflow experiment tracking
mlruns/

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# OS artefacts
.DS_Store
Thumbs.db

# ── Data directories (only .gitkeep files are tracked) ────────────────────────
data/raw/*
data/interim/*
data/processed/*
data/external/*
!data/**/.gitkeep
# Exception: the example seeding CSV is checked in as reference.
!data/processed/wc2026_seeding_example.csv

# ── Model artefacts ────────────────────────────────────────────────────────────
models/*.pkl
models/*.joblib
models/*.json
models/*.txt
!models/README.md

# ── Generated outputs ─────────────────────────────────────────────────────────
outputs/figures/*
outputs/plots/*
outputs/simulations/*
outputs/reports/*
outputs/predictions/*
!outputs/**/.gitkeep